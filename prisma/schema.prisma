generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STANDARD
  AURUM
  BOARDROOM
  ADMIN
}

enum PostTag {
  PAYOUT
  AURUM_RESULTS
  CHALLENGE_PASSED
  GENERAL
  QUESTION
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum EAStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
}

enum FileType {
  EA_FILE
  SET_FILE
  PDF_GUIDE
  BROKER_SETTINGS
}

model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique
  email      String   @unique
  fullName   String?
  phone      String?
  avatarUrl  String?
  role       Role     @default(STANDARD)

  referralCode String @unique @default(cuid())

  emailNotifications Boolean @default(true)
  communityAlerts    Boolean @default(true)
  payoutUpdates      Boolean @default(true)

  checkInEmailSentAt DateTime? // 30-day check-in email sent once

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts         Post[]
  comments      Comment[]
  likes         Like[]
  userEAs       UserEA[]
  eaRequests    EARequest[]
  tickets       SupportTicket[]
  ticketReplies TicketReply[]
  leaderboard   LeaderboardEntry[]
  referralsSent Referral[]         @relation("ReferralSender")
  referredBy    Referral[]         @relation("ReferralConverted")
  mtAccounts    MTAccount[]
}

model Post {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content  String
  tag      PostTag  @default(GENERAL)
  amount   Decimal? @db.Decimal(12, 2)
  imageUrl String?
  isPinned Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]
  likes    Like[]
}

model Comment {
  id      String @id @default(cuid())
  postId  String
  post    Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  content String

  createdAt DateTime @default(now())
}

model Like {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model EA {
  id           String   @id @default(cuid())
  name         String
  description  String?
  version      String   @default("1.0")
  requiredRole Role     @default(STANDARD)
  status       EAStatus @default(ACTIVE)
  downloadUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userEAs   UserEA[]
  downloads Download[]
}

model UserEA {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eaId          String
  ea            EA       @relation(fields: [eaId], references: [id], onDelete: Cascade)
  accountNumber String?
  broker        String?
  status        EAStatus @default(ACTIVE)

  assignedAt DateTime @default(now())

  @@unique([userId, eaId])
}

model Download {
  id           String   @id @default(cuid())
  eaId         String?
  ea           EA?      @relation(fields: [eaId], references: [id], onDelete: SetNull)
  name         String
  description  String?
  fileType     FileType
  fileUrl      String
  version      String
  isLatest     Boolean  @default(true)
  requiredRole Role     @default(STANDARD)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Video {
  id           String  @id @default(cuid())
  title        String
  description  String?
  duration     String?
  embedUrl     String
  category     String
  isFeatured   Boolean @default(false)
  thumbnail    String?
  requiredRole Role    @default(STANDARD)
  sortOrder    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String
  description   String
  priority      TicketPriority @default(MEDIUM)
  status        TicketStatus   @default(OPEN)
  screenshotUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replies TicketReply[]
}

model TicketReply {
  id       String        @id @default(cuid())
  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content  String
  isAdmin  Boolean       @default(false)

  createdAt DateTime @default(now())
}

model LeaderboardEntry {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  month    String
  year     Int
  system   String
  propFirm String?
  payout   Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@unique([userId, month, year])
}

model TickerItem {
  id        String   @id @default(cuid())
  text      String
  amount    Decimal? @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
}

model EARequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eaName    String?
  message   String
  status    String   @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model MTAccount {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metaApiAccountId String   @unique
  login            String
  server           String
  platform         String   // mt4 | mt5
  name             String?
  broker           String?
  region           String?  // MetaApi region for trading API (e.g. new-york, vint-hill)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Referral {
  id              String  @id @default(cuid())
  senderId        String
  sender          User    @relation("ReferralSender", fields: [senderId], references: [id], onDelete: Cascade)
  email           String
  signedUp        Boolean @default(false)
  isConverted     Boolean @default(false)
  convertedUserId String?
  convertedUser   User?   @relation("ReferralConverted", fields: [convertedUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
